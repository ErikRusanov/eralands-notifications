# Application
APP__HOST=0.0.0.0
APP__PORT=8000
APP__ENV=dev
APP__LOGGING_LEVEL=INFO

# Database (PostgreSQL)
DB__HOST=localhost
DB__PORT=5432
DB__NAME=notifications
DB__USER=notifications
DB__PASSWORD=notifications

# Telegram bot
TELEGRAM__TOKEN=
TELEGRAM__WEBHOOK_URL=
TELEGRAM__WEBHOOK_PATH=/api/bot/webhook
# Случайная строка [A-Za-z0-9_-], 1-256 символов. Telegram вернёт её в
# заголовке X-Telegram-Bot-Api-Secret-Token; сервис её проверяет.
# Пустая строка — без проверки (только для локальной разработки).
TELEGRAM__WEBHOOK_SECRET=

# API key (bearer для /api/clients и /api/landings)
API__KEY=change-me

# Linking codes
LINKING_CODE__TTL_MINUTES=60
LINKING_CODE__LENGTH=8
