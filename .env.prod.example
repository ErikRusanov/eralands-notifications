# Application
APP__HOST=0.0.0.0
APP__PORT=8000
APP__ENV=prod
APP__LOGGING_LEVEL=INFO

# Database (PostgreSQL)
# DB__HOST в проде равен 'postgres' (имя сервиса в compose).
# Это значение перекрывается через environment в docker-compose.prod.yml,
# поэтому здесь можно оставить как есть.
DB__HOST=postgres
DB__PORT=5432
DB__NAME=notifications
DB__USER=notifications
DB__PASSWORD=change-me-strong-random-password

# Telegram bot
TELEGRAM__TOKEN=
TELEGRAM__WEBHOOK_URL=https://your-domain.example.com
TELEGRAM__WEBHOOK_PATH=/api/bot/webhook
# Случайная строка [A-Za-z0-9_-], 32+ символов. Telegram возвращает её
# в заголовке X-Telegram-Bot-Api-Secret-Token; сервис проверяет.
TELEGRAM__WEBHOOK_SECRET=

# API key (bearer для /api/clients и /api/landings)
API__KEY=change-me-strong-random-key

# Linking codes
LINKING_CODE__TTL_MINUTES=60
LINKING_CODE__LENGTH=8

# === Параметры для скрипта деплоя (scripts/deploy) ===
# Эти переменные читает только make deploy. Само приложение их игнорирует
# (extra="ignore" в Settings).
DEPLOY__SSH_USER=root
DEPLOY__SSH_HOST=
DEPLOY__DOMAIN=
DEPLOY__REMOTE_DIR=/opt/eralands-notifications
DEPLOY__BACKUP_RETENTION=5
